generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Second client for the thermal-worker service. Identical schema, separate
// output path so each deployable has its own copy. Saves us duplicating
// the schema file across the repo.
generator workerClient {
  provider = "prisma-client"
  output   = "../thermal-worker/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ProcessedDate {
  id              Int       @id @default(autoincrement())
  source          String    // "bga" or "weglide"
  date            DateTime  @db.Date
  flightCount     Int
  thermalCount    Int       @default(0)
  algorithmVersion String
  processedAt     DateTime  @default(now())
  lastCheckedAt   DateTime?
  flights         Flight[]

  @@unique([source, date])
  @@index([source, date])
  @@map("processed_dates")
}

model Flight {
  id              Int      @id @default(autoincrement())
  sourceId        String   // e.g. "bga:128982"
  source          String
  date            DateTime @db.Date
  pilot           String
  club            String
  aircraft        String
  registration    String?
  launchSite      String
  region          String?  // ISO region code, e.g. "GB", "DE"
  launchLat       Float
  launchLon       Float
  distance        Float    // km
  speed           Float?   // km/h
  points          Int?
  sourceUrl       String
  hasTrackData    Boolean
  processed       Boolean  @default(false)
  processedDateId Int?
  processedDate   ProcessedDate? @relation(fields: [processedDateId], references: [id])
  thermals        Thermal[]

  @@unique([sourceId])
  @@index([source, date])
  @@map("flights")
}

model Thermal {
  id           Int      @id @default(autoincrement())
  lat          Float
  lon          Float
  avgClimbRate Float    // m/s
  altGain      Float    // metres
  baseAlt      Float    // metres
  topAlt       Float    // metres
  entryTime    DateTime
  exitTime     DateTime
  flightId     Int
  flight       Flight   @relation(fields: [flightId], references: [id], onDelete: Cascade)

  @@index([flightId])
  @@map("thermals")
}

model LivePosition {
  id           Int      @id @default(autoincrement())
  deviceId     String
  registration String?
  model        String?
  lat          Float
  lon          Float
  altMetres    Float
  groundKt     Float
  climbRateMs  Float
  aircraftType Int
  timestamp    DateTime
  fetchedAt    DateTime @default(now())

  @@unique([deviceId, timestamp])
  @@index([fetchedAt])
  @@map("live_positions")
}

model PollState {
  id             Int      @id @default(1)
  lastPollAt     DateTime @default(now())
  lastPositionTs DateTime @default(now())

  @@map("poll_state")
}

model LiveThermal {
  id           Int      @id @default(autoincrement())
  deviceId     String
  lat          Float
  lon          Float
  avgClimbRate Float
  altGain      Float
  baseAlt      Float
  topAlt       Float
  entryTime    DateTime
  exitTime     DateTime
  detectedAt   DateTime @default(now())

  @@unique([deviceId, entryTime])
  @@index([detectedAt])
  @@map("live_thermals")
}
